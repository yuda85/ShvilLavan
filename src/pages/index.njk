            </div>
        </div>
    </section>

    <!-- Why Choose Us - Icon Bar -->
    <section class="why-us" id="why-us">
        <div class="why-us-bg">
            <picture>
                <source srcset="/images/texture-green.webp" type="image/webp">
                <img src="/images/texture-green.jpg" alt="" class="why-us-bg-img" width="463" height="79">
            </picture>
        </div>
        <div class="container">
            <h2 class="why-us-title">{{ whyUs.title }}</h2>
            <div class="why-us-grid">
{%- for item in whyUs.items %}
                <div class="why-us-item">
                    <div class="why-us-icon">
                        <i aria-hidden="true" class="fa-solid {{ item.icon }}"></i>
                    </div>
                    <h3>{{ item.title }}</h3>
                    <p>{{ item.text }}</p>
                </div>
{%- endfor %}
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section class="contact" id="contact">
        <div class="container">
            <h2 class="section-title">{{ contact.title }}</h2>
            <p class="section-subtitle">{{ contact.subtitle }}</p>
            <div class="contact-wrapper">
                <form class="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
                    <input type="hidden" name="form-name" value="contact">
                    <p class="hidden" aria-hidden="true">
                        <label>Don't fill this out: <input name="bot-field"></label>
                    </p>
                    <div class="form-group">
                        <label for="name">שם מלא</label>
                        <input type="text" id="name" name="name" required aria-required="true" placeholder="השם שלכם">
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="phone">טלפון</label>
                            <input type="tel" id="phone" name="phone" required aria-required="true" placeholder="05X-XXX-XXXX" dir="ltr">
                        </div>
                        <div class="form-group">
                            <label for="email">אימייל</label>
                            <input type="email" id="email" name="email" placeholder="email@example.com" dir="ltr">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="route">מסלול</label>
                        <select id="route" name="route" required aria-required="true">
                            <option value="" disabled selected>בחרו מסלול</option>
{%- for opt in contact.routeOptions %}
                            <option value="{{ opt }}">{{ opt }}</option>
{%- endfor %}
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="message">הודעה</label>
                        <textarea id="message" name="message" rows="4" placeholder="ספרו לנו על הטיול שאתם מתכננים..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-full">שלחו הודעה</button>
                </form>
                <div class="form-success" id="formSuccess" aria-live="polite">
