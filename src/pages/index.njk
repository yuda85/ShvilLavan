{# #}    <!-- Hero Section 1 - Hikers -->
    <section class="hero" id="hero">
        <div class="hero-bg">
            <picture>
                <source srcset="/images/{{ hero.image }}.webp" type="image/webp">
                <img src="/images/{{ hero.image }}.jpg" alt="{{ hero.imageAlt }}" class="hero-bg-img" width="1920" height="792">
            </picture>
            <div class="hero-overlay"></div>
        </div>
        <div class="hero-content">
            <h1 class="hero-title">{{ hero.h1 }}</h1>
            <p class="hero-subtitle">{{ hero.subtitle }}</p>
            <p class="hero-description">{{ hero.description | safe }}</p>
            <div class="hero-cta">
                <a href="{{ hero.ctaPrimaryHref }}" class="btn btn-primary">{{ hero.ctaPrimaryText }}</a>
                <a href="{{ hero.ctaSecondaryHref }}" class="btn btn-outline">{{ hero.ctaSecondaryText }}</a>
            </div>
        </div>
    </section>

    <!-- Services Strip -->
    <section class="services" id="services">
        <div class="container">
            <h2 class="section-title">{{ services.title }}</h2>
            <div class="services-grid">
{%- for item in services.items %}
                <div class="service-card">
                    <div class="service-icon">
                        {{ serviceIcons[item.icon] | safe }}
                    </div>
                    <h3 class="service-title">{{ item.title }}</h3>
                    <p class="service-text">{{ item.text }}</p>
                </div>
{%- endfor %}
            </div>
        </div>
    </section>

    <!-- Hero Section 2 - Campsite Sunset -->
    <section class="hero-secondary">
        <div class="hero-secondary-bg">
            <picture>
                <source srcset="/images/{{ heroSecondary.image }}.webp" type="image/webp">
                <img src="/images/{{ heroSecondary.image }}.jpg" alt="{{ heroSecondary.imageAlt }}" class="hero-secondary-bg-img" width="1920" height="505">
            </picture>
        </div>
    </section>

    <!-- Gallery Section - 4 images 2x2 with text overlays -->
    <section class="gallery" id="gallery">
        <h2 class="sr-only">השירותים שלנו בתמונות</h2>
        <div class="gallery-grid-full">
{%- for item in gallery.items %}
            <div class="gallery-item-overlay">
                <picture>
                    <source srcset="/images/{{ item.image }}.webp" type="image/webp">
                    <img src="/images/{{ item.image }}.jpg" alt="{{ item.imageAlt }}" loading="lazy" width="{{ item.width }}" height="{{ item.height }}">
                </picture>
                <div class="gallery-overlay"></div>
                <div class="gallery-text">
                    <h3>{{ item.title }}</h3>
                    <p>{{ item.text }}</p>
                </div>
            </div>
{%- endfor %}
        </div>
    </section>

    <!-- Routes Section -->
    <section class="routes" id="routes">
        <div class="container">
            <h2 class="section-title">{{ routes.title }}</h2>
            <p class="section-subtitle">{{ routes.subtitle }}</p>
            <div class="routes-grid">
{%- for item in routes.items %}
                <div class="route-card">
                    <div class="route-icon">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    </div>
                    <h3 class="route-name">{{ item.name }}</h3>
                    <p class="route-info">{{ item.info | safe }}</p>
                    <p class="route-desc">{{ item.desc }}</p>
                    <a href="{{ item.ctaHref }}" class="btn btn-small">{{ item.ctaText }}</a>
                </div>
{%- endfor %}
            </div>
        </div>
    </section>

    <!-- Family Hosting Section -->
    <section class="family-hosting" id="family-hosting">
        <div class="container">
            <h2 class="section-title">{{ familyHosting.title }}</h2>
            <p class="section-subtitle">{{ familyHosting.subtitle }}</p>
            <div class="content-with-image">
                <div>
                    <p>{{ familyHosting.paragraph1 }}</p>
                    <p>{{ familyHosting.paragraph2 }}</p>
                </div>
                <div class="content-image">
                    <picture>
                        <source srcset="/images/{{ familyHosting.image }}.webp" type="image/webp">
                        <img src="/images/{{ familyHosting.image }}.jpg" alt="{{ familyHosting.imageAlt }}" loading="lazy" width="1920" height="739">
                    </picture>
                </div>
            </div>
            <div class="feature-list" style="margin-top: 40px;">
{%- for feat in familyHosting.features %}
